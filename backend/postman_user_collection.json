{
  "info": {
    "name": "User Routes Collection",
    "_postman_id": "user-routes-collection",
    "description": "Postman collection for the Express `routes/user.js` endpoints",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "userId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "User Routes",
      "item": [
        {
          "name": "Google Login (POST /user/google-login)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"credential\": \"<GOOGLE_ID_TOKEN>\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/user/google-login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "user",
                "google-login"
              ]
            }
          }
        },
        {
          "name": "Login (POST /user/login)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Alice\",\n  \"email\": \"alice@example.com\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/user/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "user",
                "login"
              ]
            }
          }
        },
        {
          "name": "Get Profile (GET /user/:id/profile)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/user/{{userId}}/profile",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "user",
                "{{userId}}",
                "profile"
              ]
            }
          }
        },
        {
          "name": "Create Profile Details (POST /user/profileDetails)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user\": \"{{userId}}\",\n  \"bio\": \"This is my bio\",\n  \"website\": \"https://example.com\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/user/profileDetails",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "user",
                "profileDetails"
              ]
            }
          }
        },
        {
          "name": "Get Profile Details (GET /user/profileDetails)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/user/profileDetails",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "user",
                "profileDetails"
              ]
            }
          }
        },
        {
          "name": "Create MyPost (POST /user/:id/myPosts)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"My post title\",\n  \"content\": \"Hello world\",\n  \"media\": []\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/user/{{userId}}/myPosts",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "user",
                "{{userId}}",
                "myPosts"
              ]
            }
          }
        },
        {
          "name": "Get MyPosts (GET /user/:id/myPosts)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/user/{{userId}}/myPosts",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "user",
                "{{userId}}",
                "myPosts"
              ]
            }
          }
        },
        {
          "name": "Edit MyPosts (PUT /user/:id/myPosts)",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": { 
              "mode": "raw",
              "raw": "{\n  \"title\": \"Updated title\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/user/{{userId}}/myPosts",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "user",
                "{{userId}}",
                "myPosts"
              ]
            }
          }
        }
      ]
    }
  ]
}
